# Copy to .env and fill in values

# PostgreSQL connection string from Railway
DATABASE_URL=postgresql://user:password@host:port/dbname

# Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Your Clerk publishable key (for JWT verification)
CLERK_PUBLISHABLE_KEY=pk_...

# Frontend URL (no trailing slash)
ALLOWED_ORIGIN=http://localhost:5173

# JIRA cross-posting for bugs (optional — the toggle stays disabled on the
# client if these aren't set). Base URL has no trailing slash. The token is
# a personal API token from https://id.atlassian.com/manage-profile/security/api-tokens,
# not your account password.
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=

NODE_ENV=development
